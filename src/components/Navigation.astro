---
const { class: className } = Astro.props
---

<header class:list={['sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur-sm', className]}>
  <nav class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2 transition-opacity hover:opacity-90">
      <span class="text-2xl font-black tracking-tighter text-slate-900 uppercase">
        Tim <span class="text-red-600">Dorr</span>
      </span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <a
        href="/about"
        class="text-sm font-semibold tracking-wider text-slate-600 uppercase transition-colors hover:text-blue-700"
        >About</a
      >
      <a
        href="/issues"
        class="text-sm font-semibold tracking-wider text-slate-600 uppercase transition-colors hover:text-blue-700"
        >Issues</a
      >
      <a
        href="/volunteer"
        class="text-sm font-semibold tracking-wider text-slate-600 uppercase transition-colors hover:text-blue-700"
        >Volunteer</a
      >
      <a
        href="/donate"
        class="transform rounded-full bg-red-600 px-6 py-2.5 text-sm font-bold tracking-widest text-white uppercase shadow-md transition-all hover:scale-105 hover:bg-red-700"
      >
        Donate
      </a>
    </div>

    <div class="md:hidden">
      <button type="button" class="p-2 text-slate-900">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
        </svg>
      </button>
    </div>
  </nav>
</header>
