---
import Layout from '../layouts/Layout.astro'
import mapData from '../data/map.json'
---

<Layout
  hideNav
  hideFooter
  title="District Map | Tim Dorr for Georgia"
  description="Check if you live in Georgia House District 53. Enter your address or use your current location to see if you are in the district."
>
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
  <script
    is:inline
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""></script>

  <main class="flex grow flex-col bg-white">
    <section class="border-b border-slate-200 bg-slate-50 py-12">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="mb-8 text-center">
          <h1 class="text-brand-navy text-3xl font-black tracking-tight uppercase sm:text-4xl">Am I in District 53?</h1>
          <p class="mt-4 text-lg text-slate-600">
            Enter your address or use your location to see if you're part of House District 53.
          </p>
        </div>

        <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
          <form id="lookup-form" class="space-y-4">
            <div class="flex flex-col gap-4 sm:flex-row">
              <div class="relative flex-1">
                <input
                  type="text"
                  id="address"
                  placeholder="Enter your address..."
                  class="focus:border-brand-blue focus:ring-brand-blue/10 w-full rounded-xl border border-slate-300 px-4 py-3 pr-10 transition-all outline-none focus:ring-4"
                />
                <div id="loading-spinner" class="absolute top-3.5 right-3 hidden">
                  <svg class="h-5 w-5 animate-spin text-slate-400" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"
                    ></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                  </svg>
                </div>
              </div>
              <button
                type="submit"
                class="bg-brand-navy hover:bg-brand-navy/90 rounded-xl px-8 py-3 font-bold text-white transition-all"
              >
                Check Address
              </button>
              <button
                type="button"
                id="use-location"
                class="inline-flex items-center justify-center gap-2 rounded-xl border border-slate-300 bg-white px-6 py-3 font-bold text-slate-700 transition-all hover:bg-slate-50"
              >
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Use My Location
              </button>
            </div>
          </form>

          <div id="result" class="mt-6 hidden rounded-xl p-4 text-center text-lg font-bold transition-all"></div>
        </div>
      </div>
    </section>

    <div id="map" class="z-0 min-h-[600px] w-full grow border-t border-slate-200"></div>
  </main>

  <script is:inline define:vars={{ mapData }}>
    document.addEventListener('DOMContentLoaded', () => {
      const map = L.map('map', { scrollWheelZoom: false }).setView([33.92, -84.37], 12)

      L.tileLayer('https://tiles.stadiamaps.com/tiles/alidade_smooth/{z}/{x}/{y}{r}.png', {
        maxZoom: 20,
        attribution: '&copy; <a href="https://stadiamaps.com/">Stadia Maps</a>',
      }).addTo(map)

      const districtLayer = L.geoJSON(mapData, {
        style: {
          color: '#f39357',
          weight: 3,
          opacity: 1,
          fillColor: '#185f9c',
          fillOpacity: 0.15,
        },
      }).addTo(map)

      map.fitBounds(districtLayer.getBounds(), { padding: [20, 20] })

      let marker = null

      // Point in Polygon algorithm (Ray Casting)
      function isPointInPolygon(point, polygon) {
        const x = point[0],
          y = point[1]
        let inside = false
        for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
          const xi = polygon[i][0],
            yi = polygon[i][1]
          const xj = polygon[j][0],
            yj = polygon[j][1]
          const intersect = yi > y !== yj > y && x < ((xj - xi) * (y - yi)) / (yj - yi) + xi
          if (intersect) inside = !inside
        }
        return inside
      }

      function checkLocation(lat, lng) {
        const point = [lng, lat] // GeoJSON is [lng, lat]
        const polygon = mapData.geometry.coordinates[0]
        const isInside = isPointInPolygon(point, polygon)

        const resultDiv = document.getElementById('result')
        resultDiv.classList.remove('hidden', 'bg-green-100', 'text-green-800', 'bg-red-100', 'text-red-800')

        if (isInside) {
          resultDiv.textContent = 'Yes! You are in Georgia House District 53.'
          resultDiv.classList.add('bg-green-100', 'text-green-800')
        } else {
          resultDiv.textContent = 'You are not in Georgia House District 53.'
          resultDiv.classList.add('bg-red-100', 'text-red-800')
        }

        if (marker) map.removeLayer(marker)
        marker = L.marker([lat, lng]).addTo(map)
        map.setView([lat, lng], 14)
      }

      // Handle Address Lookup
      const form = document.getElementById('lookup-form')
      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        const address = document.getElementById('address').value
        if (!address) return

        const spinner = document.getElementById('loading-spinner')
        spinner.classList.remove('hidden')

        try {
          const response = await fetch(
            `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address + ', GA')}`,
          )
          const data = await response.json()

          if (data && data.length > 0) {
            const { lat, lon } = data[0]
            checkLocation(parseFloat(lat), parseFloat(lon))
          } else {
            alert('Address not found. Please try again.')
          }
        } catch (error) {
          console.error('Lookup error:', error)
          alert('Error looking up address.')
        } finally {
          spinner.classList.add('hidden')
        }
      })

      // Handle Current Location
      const locationBtn = document.getElementById('use-location')
      locationBtn.addEventListener('click', () => {
        if (!navigator.geolocation) {
          alert('Geolocation is not supported by your browser.')
          return
        }

        locationBtn.disabled = true
        locationBtn.textContent = 'Locating...'

        navigator.geolocation.getCurrentPosition(
          (position) => {
            const { latitude, longitude } = position.coords
            checkLocation(latitude, longitude)
            locationBtn.disabled = false
            locationBtn.innerHTML = `
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Use My Location
            `
          },
          (error) => {
            console.error('Geolocation error:', error)
            alert('Unable to retrieve your location.')
            locationBtn.disabled = false
            locationBtn.textContent = 'Use My Location'
          },
        )
      })
    })
  </script>
</Layout>
