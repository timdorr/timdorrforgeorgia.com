---
import Layout from '../layouts/Layout.astro'

const donationAmounts = [10, 25, 50, 100, 250, 500, 1000]
---

<Layout title="Donate | Tim Dorr for Georgia">
  <main class="flex grow flex-col items-center justify-center bg-white py-24">
    <div class="mx-auto max-w-3xl space-y-12 px-4 text-center sm:px-6 lg:px-8">
      <div class="space-y-4">
        <h1 class="text-4xl font-black tracking-tight text-balance uppercase sm:text-6xl">Support the Campaign</h1>
        <div class="bg-brand-orange mx-auto h-2 w-20 rounded-full text-balance"></div>
        <p class="text-xl font-medium text-slate-600">
          Your contribution helps us reach voters across District 53 and build a stronger Georgia.
        </p>
      </div>

      <div class="space-y-8 rounded-3xl border border-slate-200 bg-slate-50 p-8 shadow-sm sm:p-12">
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
          {
            donationAmounts.map((amount) => (
              <button class="hover:border-brand-blue hover:bg-brand-blue/5 hover:text-brand-blue rounded-xl border-2 border-slate-300 py-4 text-lg font-black text-slate-700 transition-all">
                ${amount}
              </button>
            ))
          }
          <button
            class="hover:border-brand-blue hover:bg-brand-blue/5 hover:text-brand-blue rounded-xl border-2 border-slate-300 py-4 text-lg font-black text-slate-700 transition-all"
          >
            Other
          </button>
        </div>

        <div class="pt-4">
          <a
            href="#"
            class="bg-brand-orange shadow-brand-orange/20 hover:bg-brand-orange/90 inline-block w-full rounded-xl py-5 text-lg font-black tracking-widest text-white uppercase shadow-xl transition-all"
          >
            Continue to Donate
          </a>
        </div>

        <div class="space-y-2 rounded-xl border border-slate-200 bg-white p-6 text-left text-xs text-slate-500">
          <p class="text-brand-navy font-bold tracking-widest uppercase">Contribution Rules</p>
          <ul class="list-inside list-disc space-y-1 leading-relaxed">
            <li>I am at least eighteen years old.</li>
            <li>
              This contribution is made from my own funds, and funds are not being provided to me by another person or
              entity for the purpose of making this contribution.
            </li>
            <li>I am a U.S. citizen or lawfully admitted permanent resident (i.e., green card holder).</li>
            <li>Contributions are not tax deductible for federal income tax purposes.</li>
          </ul>
        </div>
      </div>
    </div>
  </main>
</Layout>
