---
import Layout from '../layouts/Layout.astro'
import { Picture } from 'astro:assets'
import portrait from '../assets/portrait.jpg'
import family from '../assets/family.jpg'
import professional from '../assets/professional.jpg'
import mapData from '../data/map.json'
---

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>
<script
  is:inline
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""></script>

<Layout
  title="Tim Dorr for Georgia | Committed to Progress"
  description="Learn more about Tim Dorr's campaign for Georgia State House District 53. Committed to progress, transparency, and a stronger Georgia for all our families."
>
  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-slate-900 py-24 text-white sm:py-32">
      <!-- Visual flair -->
      <div class="absolute inset-0 z-0 opacity-20">
        <div
          class="absolute top-0 left-0 h-full w-full bg-[radial-gradient(circle_at_20%_30%,var(--color-brand-blue)_0%,transparent_50%)]"
        >
        </div>
        <div
          class="absolute right-0 bottom-0 h-full w-full bg-[radial-gradient(circle_at_80%_70%,var(--color-brand-orange)_0%,transparent_50%)]"
        >
        </div>
      </div>

      <div
        class="relative z-10 mx-auto flex max-w-7xl flex-col items-center gap-12 px-4 text-center sm:px-6 lg:flex-row lg:px-8 lg:text-left"
      >
        <div class="flex-1 space-y-8">
          <div
            class="border-brand-blue/30 bg-brand-blue/20 inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-bold tracking-widest text-white uppercase"
          >
            <span class="bg-brand-orange h-2 w-2 animate-pulse rounded-full"></span>
            Running for Georgia State House
          </div>
          <h1 class="text-5xl leading-tight font-black tracking-tight uppercase sm:text-7xl">
            <span class="text-white">Tim Dorr</span>
            <br />
            <span class="text-brand-orange">for Georgia</span>
          </h1>
          <p class="max-w-2xl text-xl leading-relaxed font-medium text-slate-200 sm:text-2xl">
            A new voice for House District 53. Committed to progress, transparency, and a stronger Georgia for all our
            families.
          </p>
          <div class="flex flex-col gap-4 pt-4 sm:flex-row">
            <a
              href="/donate"
              class="bg-brand-orange shadow-brand-orange/20 hover:bg-brand-orange/90 rounded-xl px-8 py-4 text-center text-lg font-black tracking-widest text-white uppercase shadow-xl transition-all"
            >
              Donate Now
            </a>
            <a
              href="/volunteer"
              class="text-brand-navy rounded-xl bg-white px-8 py-4 text-center text-lg font-black tracking-widest uppercase transition-all hover:bg-slate-100"
            >
              Get Involved
            </a>
          </div>
        </div>
        <div
          class="relative aspect-[3/4] w-full max-w-md flex-1 overflow-hidden rounded-3xl border border-white/10 bg-slate-800 shadow-2xl"
        >
          <Picture
            src={portrait}
            formats={['webp', 'avif']}
            fallbackFormat="jpeg"
            widths={[400, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 448px"
            alt="Tim Dorr"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </section>

    <!-- Bio Preview Section -->
    <section id="about" class="bg-white py-24">
      <div class="mx-auto flex max-w-7xl flex-col items-center gap-16 px-4 sm:px-6 lg:flex-row lg:px-8">
        <div class="flex-1 space-y-6">
          <h2 class="text-3xl font-black tracking-tight text-slate-900 uppercase sm:text-4xl">Meet Tim Dorr</h2>
          <div class="bg-brand-orange h-2 w-20 rounded-full"></div>
          <div class="space-y-4 text-lg leading-relaxed text-balance text-slate-600">
            <p class="font-bold text-slate-900 italic">
              "Georgia is more than just a place to live; it's our community, our home, and our future."
            </p>
            <p>
              I'm Tim Dorr, a husband, a dad, and someone who believes that if you work hard, you should be able to build a good life right here in Georgia.
            </p>
            <p>
              I've spent my career in technology, helping build companies and teams that created opportunities for more than 1,500 Georgians. Now, I'm stepping up to represent House District 53 because I believe our community deserves leadership that understands both how to create opportunity and how to protect it.
            </p>
            <div class="pt-4">
              <a
                href="/about"
                class="text-brand-blue inline-flex items-center gap-2 text-sm font-bold tracking-widest uppercase hover:underline"
              >
                Read the full story
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"
                  ></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
        <div class="grid w-full flex-1 grid-cols-2 gap-4">
          <div
            class="flex aspect-[3/4] items-center justify-center overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 text-slate-400"
          >
            <Picture
              src={professional}
              formats={['webp', 'avif']}
              fallbackFormat="jpeg"
              widths={[400, 800]}
              sizes="(max-width: 1024px) 50vw, 600px"
              alt="Tim Dorr professional"
              pictureAttributes={{ class: 'h-full w-full object-cover' }}
              class="h-full w-full object-cover"
            />
          </div>
          <div
            class="mt-8 flex aspect-[3/4] items-center justify-center overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 text-slate-400"
          >
            <Picture
              src={family}
              formats={['webp', 'avif']}
              fallbackFormat="jpeg"
              widths={[400, 800]}
              sizes="(max-width: 1024px) 50vw, 600px"
              alt="Tim Dorr and family"
              pictureAttributes={{ class: 'h-full w-full object-cover' }}
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Issues Preview Section -->
    <section id="issues" class="bg-slate-50 py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-16 space-y-4 text-center">
          <h2 class="text-3xl font-black tracking-tight text-slate-900 uppercase sm:text-4xl">Our Priorities</h2>
          <p class="mx-auto max-w-3xl text-xl text-slate-600">
            My priorities are built around the needs of our families and the future of our state.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          <!-- Education -->
          <div
            class="group rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-shadow hover:shadow-md"
          >
            <div
              class="mb-6 flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100 text-blue-700 transition-colors group-hover:bg-blue-600 group-hover:text-white"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
                ></path>
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-black text-slate-900 uppercase">Strong schools, strong future</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              We need to invest in our public schools, support our teachers, and make sure every child, no matter their zip code, has access to a high-quality education.
            </p>
          </div>

          <!-- Economy -->
          <div
            class="group rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-shadow hover:shadow-md"
          >
            <div
              class="mb-6 flex h-12 w-12 items-center justify-center rounded-lg bg-green-100 text-green-700 transition-colors group-hover:bg-green-600 group-hover:text-white"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-black text-slate-900 uppercase">Making life more affordable</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              We need smarter, more efficient approaches that help lower costs today while building a more sustainable and competitive future for Georgia.
            </p>
          </div>

          <!-- Healthcare -->
          <div
            class="group rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-shadow hover:shadow-md"
          >
            <div
              class="mb-6 flex h-12 w-12 items-center justify-center rounded-lg bg-red-100 text-red-700 transition-colors group-hover:bg-red-600 group-hover:text-white"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                ></path>
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-black text-slate-900 uppercase">Accessible Healthcare</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              Healthcare should be accessible, affordable, and focused on people, not paperwork. No one should have to delay care because of cost.
            </p>
          </div>

          <!-- Housing -->
          <div
            class="group rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-shadow hover:shadow-md"
          >
            <div
              class="mb-6 flex h-12 w-12 items-center justify-center rounded-lg bg-purple-100 text-purple-700 transition-colors group-hover:bg-purple-600 group-hover:text-white"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-11 1v4a1 1 0 001 1m-6 0h6"
                ></path>
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-black text-slate-900 uppercase">Housing</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              We need practical solutions that increase housing availability, support responsible development, and protect the character of our communities.
            </p>
          </div>

          <!-- Childcare & Working Families -->
          <div
            class="group rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-shadow hover:shadow-md"
          >
            <div
              class="mb-6 flex h-12 w-12 items-center justify-center rounded-lg bg-orange-100 text-orange-700 transition-colors group-hover:bg-orange-600 group-hover:text-white"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-black text-slate-900 uppercase">Childcare</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              We need solutions that make childcare more affordable and accessible while supporting working families who are balancing a lot every day.
            </p>
          </div>
        </div>

        <div class="mt-12 border-t border-slate-200 pt-12 text-center">
          <a
            href="/issues"
            class="text-brand-blue inline-flex items-center gap-2 text-sm font-bold tracking-widest uppercase hover:underline"
          >
            View all positions
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section id="volunteer" class="bg-brand-blue relative overflow-hidden py-24 text-white">
      <div class="absolute inset-0 z-0">
        <div class="bg-brand-navy/60 absolute inset-0 mix-blend-multiply"></div>
        <div
          class="absolute top-0 left-0 h-full w-full bg-[radial-gradient(circle_at_10%_10%,var(--color-brand-orange)_0%,transparent_40%)] opacity-30"
        >
        </div>
      </div>

      <div class="relative z-10 mx-auto max-w-4xl space-y-8 px-4 text-center sm:px-6 lg:px-8">
        <h2 class="text-4xl leading-tight font-black tracking-tight uppercase sm:text-5xl">
          Join the Team <br />for House District 53
        </h2>
        <p class="text-xl font-medium text-slate-100">
          This campaign is powered by neighbors like you. Whether you can knock on doors, host an event, or make calls,
          your support makes the difference.
        </p>
        <div class="flex flex-col justify-center gap-4 pt-4 sm:flex-row">
          <a
            href="/volunteer"
            class="text-brand-navy shadow-brand-navy/20 rounded-xl bg-white px-10 py-4 text-center font-black tracking-widest uppercase shadow-xl transition-all hover:bg-slate-50"
          >
            Sign Up to Volunteer
          </a>
          <a
            href="/donate"
            class="bg-brand-orange shadow-brand-orange/20 hover:bg-brand-orange/90 rounded-xl px-10 py-4 text-center font-black tracking-widest text-white uppercase shadow-xl transition-all"
          >
            Donate Now
          </a>
        </div>
      </div>
    </section>

    <!-- Map Section -->
    <section id="map-section" class="bg-white py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-12 space-y-4 text-center">
          <h2 class="text-3xl font-black tracking-tight text-slate-900 uppercase sm:text-4xl">Our District</h2>
          <div class="bg-brand-orange mx-auto h-2 w-20 rounded-full"></div>
          <p class="mx-auto max-w-3xl text-xl text-slate-600">
            Proudly serving Georgia House District 53, including Sandy Springs, Buckhead, and Roswell.
          </p>
        </div>
        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-slate-50 shadow-lg">
          <div id="map" class="z-0 h-[500px] w-full"></div>
        </div>
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ mapData }}>
    document.addEventListener('DOMContentLoaded', () => {
      // Initialize map centered on Sandy Springs/North Atlanta
      const map = L.map('map', { zoomControl: false }).setView([33.936, -84.3827], 11)
      map.attributionControl.setPrefix(false)
      map.dragging.disable()
      map.touchZoom.disable()
      map.doubleClickZoom.disable()
      map.scrollWheelZoom.disable()
      map.boxZoom.disable()
      map.keyboard.disable()

      L.tileLayer('https://tiles.stadiamaps.com/tiles/alidade_smooth/{z}/{x}/{y}{r}.png', {
        maxZoom: 20,
      }).addTo(map)

      // Add GeoJSON Layer
      const geojsonLayer = L.geoJSON(mapData, {
        style: {
          color: '#f39357', // brand-orange
          weight: 2,
          opacity: 1,
          fillColor: '#185f9c', // brand-blue
          fillOpacity: 0.2,
        },
        interactive: false,
      }).addTo(map)

      // Automatically fit map to district boundaries
      map.fitBounds(geojsonLayer.getBounds(), { padding: [20, 20] })
    })
  </script>
</Layout>
