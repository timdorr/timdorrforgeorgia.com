---
import Layout from '../layouts/Layout.astro'
---

<Layout
  title="Volunteer | Tim Dorr for Georgia"
  description="Join the team and help Tim Dorr represent Georgia House District 53. Sign up to volunteer for door knocking, phone banking, and more."
>
  <main class="flex grow flex-col items-center justify-center bg-white py-24">
    <div class="mx-auto max-w-3xl space-y-12 px-4 text-center sm:px-6 lg:px-8">
      <div class="space-y-4">
        <h1 class="text-4xl font-black tracking-tight text-balance uppercase sm:text-6xl">Join the Team</h1>
        <div class="bg-brand-orange mx-auto h-2 w-20 rounded-full"></div>
        <p class="text-xl font-medium text-balance text-slate-600">
          Help us build a stronger Georgia. Sign up to volunteer and make your voice heard in House District 53.
        </p>
      </div>

      <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8 text-left shadow-sm sm:p-12">
        <form class="space-y-6">
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <div class="space-y-2">
              <label for="firstName" class="text-xs font-black tracking-widest text-slate-500 uppercase"
                >First Name</label
              >
              <input
                type="text"
                id="firstName"
                name="firstName"
                required
                class="focus:border-brand-blue focus:ring-brand-blue/20 w-full rounded-xl border border-slate-300 px-4 py-3 transition-all outline-none focus:ring-4"
              />
            </div>
            <div class="space-y-2">
              <label for="lastName" class="text-xs font-black tracking-widest text-slate-500 uppercase">Last Name</label
              >
              <input
                type="text"
                id="lastName"
                name="lastName"
                required
                class="focus:border-brand-blue focus:ring-brand-blue/20 w-full rounded-xl border border-slate-300 px-4 py-3 transition-all outline-none focus:ring-4"
              />
            </div>
          </div>
          <div class="space-y-2">
            <label for="email" class="text-xs font-black tracking-widest text-slate-500 uppercase">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="focus:border-brand-blue focus:ring-brand-blue/20 w-full rounded-xl border border-slate-300 px-4 py-3 transition-all outline-none focus:ring-4"
            />
          </div>
          <div class="space-y-2">
            <label for="phone" class="text-xs font-black tracking-widest text-slate-500 uppercase"
              >Phone Number (Optional)</label
            >
            <input
              type="tel"
              id="phone"
              name="phone"
              class="focus:border-brand-blue focus:ring-brand-blue/20 w-full rounded-xl border border-slate-300 px-4 py-3 transition-all outline-none focus:ring-4"
            />
          </div>
          <div class="space-y-4 pt-4">
            <label class="block text-xs font-black tracking-widest text-slate-500 uppercase"
              >How would you like to help?</label
            >
            <div class="space-y-3">
              <label class="group flex cursor-pointer items-center gap-3">
                <input
                  type="checkbox"
                  name="interest"
                  value="door-knocking"
                  class="text-brand-blue focus:ring-brand-blue h-5 w-5 rounded border-slate-300"
                />
                <span class="group-hover:text-brand-navy font-medium text-slate-700 transition-colors"
                  >Door Knocking</span
                >
              </label>
              <label class="group flex cursor-pointer items-center gap-3">
                <input
                  type="checkbox"
                  name="interest"
                  value="phone-banking"
                  class="text-brand-blue focus:ring-brand-blue h-5 w-5 rounded border-slate-300"
                />
                <span class="group-hover:text-brand-navy font-medium text-slate-700 transition-colors"
                  >Phone Banking</span
                >
              </label>
              <label class="group flex cursor-pointer items-center gap-3">
                <input
                  type="checkbox"
                  name="interest"
                  value="host-event"
                  class="text-brand-blue focus:ring-brand-blue h-5 w-5 rounded border-slate-300"
                />
                <span class="group-hover:text-brand-navy font-medium text-slate-700 transition-colors"
                  >Hosting an Event</span
                >
              </label>
              <label class="group flex cursor-pointer items-center gap-3">
                <input
                  type="checkbox"
                  name="interest"
                  value="data-entry"
                  class="text-brand-blue focus:ring-brand-blue h-5 w-5 rounded border-slate-300"
                />
                <span class="group-hover:text-brand-navy font-medium text-slate-700 transition-colors"
                  >Data Entry / Office Work</span
                >
              </label>
            </div>
          </div>
          <button
            type="submit"
            class="bg-brand-orange shadow-brand-orange/20 hover:bg-brand-orange/90 mt-8 w-full rounded-xl py-4 font-black tracking-widest text-white uppercase shadow-xl transition-all"
          >
            Sign Up
          </button>
        </form>
      </div>
    </div>
  </main>
</Layout>
