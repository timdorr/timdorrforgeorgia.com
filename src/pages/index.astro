---
import Layout from '../layouts/Layout.astro'
import { Picture } from 'astro:assets'
import portrait from '../assets/portrait.jpg'
import logo from '../assets/logo.png'
---

<Layout
  title="Tim Dorr for Georgia | Fighting for Sandy Springs, Buckhead, & Roswell"
  description="Tim Dorr is running for the Georgia State House to represent District 53. Join us in fighting for a stronger future for Sandy Springs, Buckhead, and Roswell."
  hideNav
  hideFooter
>
  <main class="bg-brand-light-blue text-brand-navy flex min-h-screen flex-col justify-center py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center gap-12 lg:flex-row">
        <!-- Text Content -->
        <div class="flex-1 space-y-6 text-center lg:text-left">
          <Picture
            src={logo}
            formats={['webp', 'avif']}
            fallbackFormat="png"
            widths={[300, 600]}
            sizes="(max-width: 600px) 100vw, 600px"
            alt="Tim Dorr for Georgia Logo"
            class="mx-auto h-auto w-full max-w-md"
          />

          <h1 class="text-3xl font-black tracking-tight uppercase sm:text-5xl">
            Fighting for <br />
            <span class="text-brand-orange">Sandy Springs, <br />Buckhead, & Roswell</span>
          </h1>

          <a
            href="https://sos.ga.gov/sites/default/files/forms/2026%20Short%20Calendar%20.pdf"
            class="border-brand-orange bg-brand-orange/5 inline-block rounded-2xl border-2 px-8 py-6"
          >
            <p class="text-xl font-black tracking-widest uppercase sm:text-2xl">
              Vote in the <br />
              <span class="text-brand-orange">May 19th</span>
              <br />
              Democratic Primary
            </p>
          </a>

          <div class="flex flex-col justify-center gap-4 pt-6 sm:flex-row lg:justify-start">
            <a
              href="/map"
              class="bg-brand-blue hover:bg-brand-blue/90 rounded-xl px-8 py-4 text-center text-lg font-black tracking-widest text-white uppercase shadow-lg transition-all"
            >
              Am I in District 53?
            </a>
            <a
              href="https://mvp.sos.ga.gov/s/"
              class="bg-brand-navy hover:bg-brand-navy/90 rounded-xl px-8 py-4 text-center text-lg font-black tracking-widest text-white uppercase shadow-lg transition-all"
            >
              Check Registration
            </a>
            <a
              href="https://georgia.gov/register-vote"
              class="bg-brand-orange shadow-brand-orange/20 hover:bg-brand-orange/90 rounded-xl px-8 py-4 text-center text-lg font-black tracking-widest text-white uppercase shadow-xl transition-all"
            >
              Register to Vote
            </a>
          </div>
        </div>

        <!-- Headshot -->
        <div class="relative w-full max-w-lg lg:flex-1">
          <div class="bg-brand-blue/10 absolute -inset-4 rounded-[2rem] blur-2xl"></div>
          <div class="border-brand-navy/10 relative aspect-[3/4] overflow-hidden rounded-[2rem] border-2 shadow-2xl">
            <Picture
              src={portrait}
              formats={['webp', 'avif']}
              fallbackFormat="jpeg"
              widths={[400, 800, 1200]}
              sizes="(max-width: 768px) 100vw, 600px"
              alt="Tim Dorr"
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>

      <!-- Disclaimer -->
      <div class="mt-24 flex justify-center">
        <div
          class="border-brand-navy rounded-sm border-2 px-6 py-4 text-center text-xs font-bold tracking-[0.2em] uppercase"
        >
          Paid for by Tim Dorr for Georgia
        </div>
      </div>
    </div>
  </main>
</Layout>
