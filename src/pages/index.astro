---
import Layout from '../layouts/Layout.astro'
import { Image } from 'astro:assets'
import portrait from '../assets/portrait.jpg'
import family from '../assets/family.jpg'
import professional from '../assets/professional.jpg'
---

<Layout>
  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-slate-900 py-24 text-white sm:py-32">
      <!-- Visual flair -->
      <div class="absolute inset-0 z-0 opacity-20">
        <div
          class="absolute top-0 left-0 h-full w-full bg-[radial-gradient(circle_at_20%_30%,#3b82f6_0%,transparent_50%)]"
        >
        </div>
        <div
          class="absolute right-0 bottom-0 h-full w-full bg-[radial-gradient(circle_at_80%_70%,#ef4444_0%,transparent_50%)]"
        >
        </div>
      </div>

      <div
        class="relative z-10 mx-auto flex max-w-7xl flex-col items-center gap-12 px-4 text-center sm:px-6 lg:flex-row lg:px-8 lg:text-left"
      >
        <div class="flex-1 space-y-8">
          <div
            class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-3 py-1 text-xs font-bold tracking-widest text-blue-400 uppercase"
          >
            <span class="h-2 w-2 animate-pulse rounded-full bg-blue-500"></span>
            Running for Georgia State House
          </div>
          <h1 class="text-5xl leading-tight font-black tracking-tight uppercase sm:text-7xl">
            Tim <span class="text-blue-500">Dorr</span>
            <br />
            <span class="text-white">for Georgia</span>
          </h1>
          <p class="max-w-2xl text-xl leading-relaxed font-medium text-slate-300 sm:text-2xl">
            A new voice for House District 53. Committed to progress, transparency, and a stronger Georgia for all our
            families.
          </p>
          <div class="flex flex-col gap-4 pt-4 sm:flex-row">
            <a
              href="/donate"
              class="rounded-xl bg-red-600 px-8 py-4 text-center text-lg font-black tracking-widest text-white uppercase shadow-xl shadow-red-900/20 transition-all hover:bg-red-700"
            >
              Donate Now
            </a>
            <a
              href="/volunteer"
              class="rounded-xl bg-white px-8 py-4 text-center text-lg font-black tracking-widest text-slate-900 uppercase transition-all hover:bg-slate-100"
            >
              Get Involved
            </a>
          </div>
        </div>
        <div
          class="relative aspect-[3/4] w-full max-w-md flex-1 overflow-hidden rounded-3xl border border-slate-700 bg-slate-800 shadow-2xl"
        >
          <Image src={portrait} alt="Tim Dorr" class="h-full w-full object-cover" />
        </div>
      </div>
    </section>

    <!-- Bio Preview Section -->
    <section id="about" class="bg-white py-24">
      <div class="mx-auto flex max-w-7xl flex-col items-center gap-16 px-4 sm:px-6 lg:flex-row lg:px-8">
        <div class="flex-1 space-y-6">
          <h2 class="text-3xl font-black tracking-tight text-slate-900 uppercase sm:text-4xl">Meet Tim Dorr</h2>
          <div class="h-2 w-20 rounded-full bg-red-600"></div>
          <div class="space-y-4 text-lg leading-relaxed text-balance text-slate-600">
            <p class="font-bold text-slate-900 italic">
              "Georgia is more than just a place to live; it's our community, our home, and our future."
            </p>
            <p>
              Tim Dorr is a dedicated community leader with a passion for public service. He is running for the State
              House to represent the hardworking families of District 53.
            </p>
            <div class="pt-4">
              <a
                href="/about"
                class="inline-flex items-center gap-2 text-sm font-bold tracking-widest text-blue-600 uppercase hover:underline"
              >
                Read the full story
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"
                  ></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
        <div class="grid w-full flex-1 grid-cols-2 gap-4">
          <div
            class="flex aspect-[3/4] items-center justify-center overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 text-slate-400"
          >
            <Image src={professional} alt="Tim Dorr professional" class="h-full w-full object-cover" />
          </div>
          <div
            class="mt-8 flex aspect-[3/4] items-center justify-center overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 text-slate-400"
          >
            <Image src={family} alt="Tim Dorr and family" class="h-full w-full object-cover" />
          </div>
        </div>
      </div>
    </section>

    <!-- Issues Preview Section -->
    <section id="issues" class="bg-slate-50 py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-16 space-y-4 text-center">
          <h2 class="text-3xl font-black tracking-tight text-slate-900 uppercase sm:text-4xl">Our Priorities</h2>
          <p class="mx-auto max-w-3xl text-xl text-slate-600">
            My priorities are built around the needs of our families and the future of our state.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          <!-- Education -->
          <div
            class="group rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-shadow hover:shadow-md"
          >
            <div
              class="mb-6 flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100 text-blue-700 transition-colors group-hover:bg-blue-600 group-hover:text-white"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
                ></path>
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-black text-slate-900 uppercase">Education First</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              Investing in our children is an investment in Georgia's future. We must support our teachers and fully
              fund our schools.
            </p>
          </div>

          <!-- Economy -->
          <div
            class="group rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-shadow hover:shadow-md"
          >
            <div
              class="mb-6 flex h-12 w-12 items-center justify-center rounded-lg bg-green-100 text-green-700 transition-colors group-hover:bg-green-600 group-hover:text-white"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-black text-slate-900 uppercase">Sustainable Economy</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              Strengthening our local economy by supporting small businesses and ensuring quality job growth in District
              53.
            </p>
          </div>

          <!-- Healthcare -->
          <div
            class="group rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-shadow hover:shadow-md"
          >
            <div
              class="mb-6 flex h-12 w-12 items-center justify-center rounded-lg bg-red-100 text-red-700 transition-colors group-hover:bg-red-600 group-hover:text-white"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                ></path>
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-black text-slate-900 uppercase">Accessible Healthcare</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              Expanding access to affordable healthcare and mental health services for every Georgian.
            </p>
          </div>
        </div>

        <div class="mt-12 border-t border-slate-200 pt-12 text-center">
          <a
            href="/issues"
            class="inline-flex items-center gap-2 text-sm font-bold tracking-widest text-blue-600 uppercase hover:underline"
          >
            View all positions
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section id="volunteer" class="relative overflow-hidden bg-blue-700 py-24 text-white">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-blue-800 mix-blend-multiply"></div>
        <div
          class="absolute top-0 left-0 h-full w-full bg-[radial-gradient(circle_at_10%_10%,#ef4444_0%,transparent_40%)] opacity-30"
        >
        </div>
      </div>

      <div class="relative z-10 mx-auto max-w-4xl space-y-8 px-4 text-center sm:px-6 lg:px-8">
        <h2 class="text-4xl leading-tight font-black tracking-tight uppercase sm:text-5xl">
          Join the Team <br />for House District 53
        </h2>
        <p class="text-xl font-medium text-blue-100">
          This campaign is powered by neighbors like you. Whether you can knock on doors, host an event, or make calls,
          your support makes the difference.
        </p>
        <div class="flex flex-col justify-center gap-4 pt-4 sm:flex-row">
          <a
            href="/volunteer"
            class="rounded-xl bg-white px-10 py-4 text-center font-black tracking-widest text-blue-700 uppercase shadow-xl shadow-blue-900/40 transition-all"
          >
            Sign Up to Volunteer
          </a>
          <a
            href="/donate"
            class="rounded-xl bg-red-600 px-10 py-4 text-center font-black tracking-widest text-white uppercase shadow-xl shadow-red-900/40 transition-all hover:bg-red-700"
          >
            Donate Now
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
